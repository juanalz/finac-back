model User {
  id           String        @id @default(uuid())
  username     String        @unique
  passwordHash String
  role         UserRole      @default(USER)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  transactions Transaction[]
  payCycles    PayCycle[]

  @@map("users")
}

enum UserRole {
  ADMIN
  USER
}
